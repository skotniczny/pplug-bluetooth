#: ../src/bluetooth.c:1306
#, c-format
msgid "Pairing request sent to '%s' - waiting for response..."
msgstr "Żądanie sparowania wysłane do „%s” – oczekiwanie na odpowiedź…"

#: ../src/bluetooth.c:1315
#, c-format
msgid "Pairing failed - %s"
msgstr "Sparowanie nie powiodło się – %s"

#: ../src/bluetooth.c:1323
#, c-format
msgid "Pairing successful - connecting..."
msgstr "Sparowanie udane – nawiązywanie połączenia…"

#: ../src/bluetooth.c:1331
#, c-format
msgid "Connection successful"
msgstr "Połączenie nawiązane pomyślnie"

#: ../src/bluetooth.c:1339 ../src/bluetooth.c:1602
#, c-format
msgid "Connection failed - %s"
msgstr "Połączenie nie powiodło się – %s"

#: ../src/bluetooth.c:1347
#, c-format
msgid "Please enter code '%s' on '%s'"
msgstr "Proszę wprowadzić kod „%s” na „%s”"

#: ../src/bluetooth.c:1355
#, c-format
msgid "Please confirm that '%s' is showing the code '%s' to pair"
msgstr "Proszę potwierdzić, że „%s” wyświetla kod „%s” do sparowania"

#: ../src/bluetooth.c:1363
#, c-format
msgid "Please enter PIN code shown on '%s'"
msgstr "Proszę wprowadzić kod PIN wyświetlony na „%s”"

#: ../src/bluetooth.c:1371
#, c-format
msgid "Please enter passcode shown on '%s'"
msgstr "Proszę wprowadzić kod dostępu wyświetlony na „%s”"

#: ../src/bluetooth.c:1379
#, c-format
msgid "Waiting for response from Bluetooth device..."
msgstr "Oczekiwanie na odpowiedź z urządzenia Bluetooth…"

#: ../src/bluetooth.c:1387
#, c-format
msgid "'%s' has requested a pairing. Do you accept the request?"
msgstr "„%s” zażądał sparowania. Czy zaakceptujesz żądanie?"

#: ../src/bluetooth.c:1395
#, c-format
msgid ""
"Pairing successful - right-click the volume icon to select as audio device"
msgstr ""
"Sparowanie udane – kliknij prawym przyciskiem myszy na ikonę głośności, aby "
"wybrać jako urządzenie audio"

#: ../src/bluetooth.c:1403
#, c-format
msgid ""
"Pairing successful - this device has no services which can be used with "
"Raspberry Pi"
msgstr ""
"Sparowanie udane – to urządzenie nie ma usług, które mogą być używane z "
"Raspberry Pi"

#: ../src/bluetooth.c:1582
#, c-format
msgid "Removing..."
msgstr "Usuwanie…"

#: ../src/bluetooth.c:1586
#, c-format
msgid "Do you want to unpair '%s'?"
msgstr "Czy chcesz anulować sparowanie z „%s”?"

#: ../src/bluetooth.c:1589
#, c-format
msgid "Removing pairing with '%s'..."
msgstr "Usuwanie sparowania z „%s”…"

#: ../src/bluetooth.c:1592
#, c-format
msgid "Removal failed - %s"
msgstr "Usunięcie nie powiodło się – %s"

#: ../src/bluetooth.c:1601
#, c-format
msgid "Connecting..."
msgstr "Łączenie…"

#: ../src/bluetooth.c:1602
#, c-format
msgid "Connecting to '%s'..."
msgstr "Łączenie z „%s”…"

#: ../src/bluetooth.c:1606
#, c-format
msgid "Disconnecting..."
